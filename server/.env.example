# Server Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANT: Never commit your actual .env file with secrets.

# Your OpenRouter API key — obtained from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# The LLM model to use (see OpenRouter documentation)
LLM_MODEL=google/gemini-2.0-flash-001

# The public URL of your frontend (required for CORS in production)
FRONTEND_URL=https://your-app-domain.vercel.app

# Server port (Vercel overrides this, but useful for local)
PORT=3001

# Set to "production" in Vercel environment
NODE_ENV=development
